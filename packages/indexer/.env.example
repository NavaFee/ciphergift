# Copy to .env.local for local dev; the indexer reads via process.env.

# Anvil running via `pnpm chain`
RPC_URL=http://127.0.0.1:8545

# Addresses written by `pnpm deploy:localhost` —
# inspect packages/site/contracts/CipherGift.local.ts after deploy.
CIPHERGIFT_ADDRESS=0x0000000000000000000000000000000000000000
VAULT_ADDRESS=0x0000000000000000000000000000000000000000

# Block to start replaying from. For local anvil, 0 is fine; for Sepolia,
# set to the block CipherGift was deployed at to skip useless scanning.
START_BLOCK=0

# HTTP port the indexer listens on. Frontend's NEXT_PUBLIC_INDEXER_URL
# must point here (e.g. http://localhost:42069).
PORT=42069

# How often to poll for new logs (ms). Lower = fresher, higher = cheaper.
POLL_INTERVAL_MS=4000

# Max blocks per eth_getLogs call. Most providers cap at 10k.
CHUNK_SIZE=10000
